# TONpayment configuration. Copy to .env and fill in. .env is gitignored —
# only this .env.example ships. Every value below is read from the environment.

# --- Server ---
TON_HTTP_ADDR=:8080            # listen address (PORT is also honored, for PaaS)
TON_ENV=dev                    # dev | prod  (prod REQUIRES TON_RECEIVING_ADDRESS)
TON_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
# Set true ONLY when behind a trusted reverse proxy; then X-Forwarded-For is used
# for rate-limit client-IP keying. Leave false on a directly-exposed server.
TON_TRUST_PROXY=false

# --- Payments (watch-only; these are PUBLIC, safe-to-set values) ---
# The TON address invoices are paid to. REQUIRED before invoices can be created.
TON_RECEIVING_ADDRESS=
# toncenter v2 API base + optional key (a key raises the rate limit above ~1 req/s).
TON_API_BASE=https://toncenter.com/api/v2
TON_API_KEY=

# --- Storage ---
# If TON_DATABASE_URL is set, Postgres is used; otherwise an in-memory/JSON store
# under TON_DATA_DIR (dev default).
TON_DATABASE_URL=
TON_DATA_DIR=data

# --- Invoicing ---
TON_DEFAULT_TTL_SECONDS=900    # invoice lifetime when a create request omits ttlSeconds
# Optional: if set, POST /v1/invoices requires this key, sent as
# "Authorization: Bearer <key>" or "X-API-Key: <key>". Leave empty to keep create open.
TON_CREATE_API_KEY=

# --- Background poller ---
TON_POLL_ENABLED=true
TON_POLL_INTERVAL_SECONDS=10
TON_POLL_CONCURRENCY=4

# --- Webhook (optional) ---
# On payment, the invoice JSON is POSTed here with header
#   X-Signature: sha256=<hex HMAC-SHA256(secret, body)>
# so the receiver can verify authenticity. Retried a few times with backoff.
TON_WEBHOOK_URL=
TON_WEBHOOK_SECRET=
