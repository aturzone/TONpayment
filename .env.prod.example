# Production .env for docker-compose.prod.yml (multi-tenant gateway platform).
# Copy to .env on the server and fill in. .env is gitignored — never commit it.
#
# Generate the secrets, e.g.:
#   POSTGRES_PASSWORD:  openssl rand -hex 24
#   TON_SESSION_SECRET: openssl rand -hex 32   (>= 16 chars required)

POSTGRES_PASSWORD=
TON_SESSION_SECRET=
TON_AUTH_DOMAINS=tonpayment.net
TON_NETWORK=mainnet
# Optional toncenter API key (raises the poller's rate limit above ~1 req/s).
TON_API_KEY=
# Upstream toncenter read budget (even-paced req/s) shared by the poller + status
# checks. Leave at 1 on the free tier; set ~10 once TON_API_KEY is configured.
TON_TONCENTER_RPS=1
# Postgres connection-pool ceiling (must stay <= postgres max_connections=100).
TON_DB_MAX_CONNS=20
# Bearer token that gates GET /metrics (Prometheus). Leave empty to disable the
# endpoint entirely. Generate: openssl rand -hex 24
TON_ADMIN_TOKEN=
# Comma-separated wallet addresses granted platform-admin (via ton_proof).
TON_ADMIN_WALLETS=
TON_ALLOWED_ORIGINS=https://tonpayment.net
